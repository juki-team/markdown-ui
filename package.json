{
  "name": "markdown-ui",
  "version": "0.1.11",
  "private": true,
  "scripts": {
    "hosts:flush": "sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder",
    "caddy:clean": "sudo killall caddy; rm -rf ~/Library/Application\\ Support/Caddy",
    "caddy": "caddy run --config Caddyfile",
    "dev": "lsof -ti:3077 | xargs kill -9 && next dev -p 3077",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "git:push": "git push origin main && git push origin --tags",
    "pull": "dotenv -- pnpm add @juki-team/commons@latest @juki-team/base-ui@latest",
    "push": "pnpm version patch && pnpm git:push;"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@ably/spaces": "^0.5.2",
    "@juki-team/base-ui": "^1.4.86",
    "@juki-team/commons": "^0.1.11",
    "@vercel/analytics": "^2.0.1",
    "ably": "^2.20.0",
    "ai": "^6.0.116",
    "fflate": "^0.8.2",
    "next": "16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "swr": "^2.4.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-next": "16.1.6",
    "prettier": "^3.8.1",
    "typescript": "^5"
  }
}
